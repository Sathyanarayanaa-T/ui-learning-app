# ============ Database Configuration ============
DATABASE_URL=sqlite:///./app.db

# ============ NVIDIA NIM Cloud Configuration (PRIMARY) ============
# Get your API key from: https://build.nvidia.com/
NVIDIA_NIM_API_KEY=nvapi-your-api-key-here
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=moonshotai/kimi-k2.6
NVIDIA_NIM_ENABLE_THINKING=True

# ============ Ollama Configuration (FALLBACK) ============
# Only needed if NVIDIA NIM is unavailable
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ============ OpenAI Configuration (FALLBACK) ============
# Only needed if both NVIDIA NIM and Ollama are unavailable
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ============ Gemini Configuration (ALTERNATIVE) ============
# Optional: Can be used as fallback alternative
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ============ Application Configuration ============
APP_NAME=AI Learning Tutor & Chatbot Backend
ENV=development
LOG_LEVEL=INFO

# ============ Chat Behavior ============
MAX_CONTEXT_MESSAGES=5
SESSION_TIMEOUT=3600

# ============ Voice Configuration ============
ENABLE_VOICE=False
DEFAULT_TTS_VOICE=alloy
ELEVENLABS_API_KEY=optional-api-key
